{
  "expo": {
    "name": "FlerimoAgro",
    "slug": "flerimoagro",
    "version": "1.0.0",
    "orientation": "portrait",
    "newArchEnabled": true,
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#2d6a4f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.flerimo.agro"
    },
    "android": {
      "package": "com.flerimo.agro",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#2d6a4f"
      }
    },
    "plugins": [
      "expo-font",
      "expo-asset"
    ]
  }
}
